set -g default-terminal "tmux-256color"
set -ga terminal-overrides ",*:RGB"
set -g mouse on
set -g set-clipboard on

{{- $zsh := lookPath "zsh" -}}
{{- if $zsh }}
set -g default-shell "{{ $zsh }}"
{{- end }}

# Start windows and panes at 1, not 0
set -g base-index 1
set -g pane-base-index 1
set-window-option -g pane-base-index 1
set-option -g renumber-windows on

# Keybinds
unbind C-b
set -g prefix M-w
set -g prefix2 None
bind M-w send-prefix

# Reload config
unbind r
bind r source-file $HOME/.config/tmux/tmux.conf

# Alt+1..8 to switch windows, Alt+9/0 to switch sessions
unbind -n M-9
unbind -n M-0
bind -n M-1 select-window -t 1
bind -n M-2 select-window -t 2
bind -n M-3 select-window -t 3
bind -n M-4 select-window -t 4
bind -n M-5 select-window -t 5
bind -n M-6 select-window -t 6
bind -n M-7 select-window -t 7
bind -n M-8 select-window -t 8
bind -n M-9 switch-client -p
bind -n M-0 switch-client -n

# Prefix+h/l to switch windows
# Prefix+(/) to switch sessions
# Prefix+o to create new window
unbind j
unbind k
bind h previous-window
bind l next-window
bind ( switch-client -p
bind ) switch-client -n
bind o new-window

# Vim like pane selection
bind -n M-h select-pane -L
bind -n M-j select-pane -D
bind -n M-k select-pane -U
bind -n M-l select-pane -R

# Vim-like copy/paste
set-window-option -g mode-keys vi
bind-key -T copy-mode-vi v send-keys -X begin-selection
bind-key -T copy-mode-vi C-v send-keys -X rectangle-toggle
bind-key -T copy-mode-vi y send-keys -X copy-selection-and-cancel
unbind -T copy-mode-vi MouseDragEnd1Pane

# Bind Alt-q to kill pane
bind -n M-q kill-pane

# Split window
unbind %
unbind '"'
bind \\ split-window -h -c "#{pane_current_path}"
bind - split-window -v -c "#{pane_current_path}"

# Toggle zoom for the current pane
unbind z
bind z resize-pane -Z

# Catppuccin
set -g @catppuccin_flavor 'frappe'
run ~/.config/tmux/plugins/tmux/catppuccin.tmux
# Show all sessions on the pane top border while keeping the main status bar at the bottom.
set -g pane-border-status top
set -g pane-border-lines spaces
set -g pane-border-format '#{S:#[fg=#{@thm_overlay_0}]#[bg=#{@thm_surface_0}] #S #[default],#[fg=#{@thm_crust}]#[bg=#{@thm_lavender}]#[bold] #S #[nobold]#[default]}'
# Make the status line more pleasant.
set -g status-left ""
set -g status-right ""

# Ensure that everything on the right side of the status line
# is included.
set -g status-right-length 100


set -g @plugin 'tmux-plugins/tpm'
set -g @plugin 'catppuccin/tmux#v2.1.3'
set -g @plugin 'omerxx/tmux-floax'
set -g @floax-bind '-n M-p'
set -g @plugin 'rickstaa/tmux-notify'
set -g @plugin 'tmux-plugins/tmux-yank'
set -g @override_copy_command 'tmux-osc52-copy'

# Auto-install tpm if not present
if "test ! -d ~/.config/tmux/plugins/tpm" \
   "run 'mkdir -p ~/.config/tmux/plugins && git clone https://github.com/tmux-plugins/tpm ~/.config/tmux/plugins/tpm'"

run '~/.config/tmux/plugins/tpm/tpm'
